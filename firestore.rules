rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Works rules: public read-only, write allowed for admin operations
    match /works/{workId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Messages rules: public create, and allow read/write for managing the inbox
    match /messages/{messageId} {
      allow read, write: if true;
    }
    
    // Metadata rules (categories, bio, settings): public read, write for configuration
    match /metadata/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
